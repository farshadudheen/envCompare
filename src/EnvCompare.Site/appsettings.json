{
  "$schema": "appsettings-schema.json",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "9f81448e-9d21-495a-8530-1e938bdaee4c"
      },
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "Security": {
        "AllowConcurrentLogins": false
      }
    }
  },
  "EnvCompare": {
    "Timeout": "00:02:00",
    "IgnoredProperties": [],
    "IgnoredContentTypes": [],
    "IgnoredPaths": [],
    "Environments": [
      {
        "Name": "Development",
        "ApiUrl": "",
        "Authentication": ""
      },
      {
        "Name": "Staging",
        "ApiUrl": "",
        "Authentication": ""
      },
      {
        "Name": "Production",
        "ApiUrl": "",
        "Authentication": ""
      }
    ]
  }
}
